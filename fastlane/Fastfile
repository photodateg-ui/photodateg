require 'base64'

default_platform(:ios)

platform :ios do
  lane :beta do
    # xcworkspaceのパスを設定（expo prebuildが生成するパス）
    workspace_path = "ios/PhotoDateG.xcworkspace"
    scheme = "PhotoDateG"
    xcodeproj_path = "ios/PhotoDateG.xcodeproj"

    UI.message("workspace: #{workspace_path}, scheme: #{scheme}")

    # CI用キーチェーン設定
    setup_ci

    # 証明書インポート
    import_certificate(
      certificate_path: "ios_dist.p12",
      certificate_password: ENV["CERTIFICATE_PASSWORD"],
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || ""
    )

    # Provisioning Profileインストール
    install_provisioning_profile(path: "dist.mobileprovision")

    # Provisioning Profile名
    profile_name = "photodateg-distribution"

    # コード署名設定
    update_code_signing_settings(
      use_automatic_signing: false,
      bundle_identifier: "com.photodateg.app",
      code_sign_identity: "iPhone Distribution",
      profile_name: profile_name,
      path: xcodeproj_path
    )

    # ビルド番号をセット
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: xcodeproj_path
    )

    # ビルド
    build_app(
      workspace: workspace_path,
      scheme: scheme,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.photodateg.app" => profile_name
        }
      },
      output_directory: "./build",
      output_name: "PhotoDateG.ipa"
    )

    # TestFlightにアップロード
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_KEY_ISSUER_ID"],
      key_content: Base64.strict_decode64(ENV["ASC_KEY_CONTENT_BASE64"]),
      duration: 1200,
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.photodateg.app",
      skip_waiting_for_build_processing: true
    )
  end
end
