      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "photodateg",
              "com.googleusercontent.apps.483467707926-haidkv7t2d0vg3pgk7ushjkovvqukdn5"
            ]
          }
        ]
      }
    },
    "scheme": "photodateg",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
